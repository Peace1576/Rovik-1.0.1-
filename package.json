{
  "name": "rovik-eve",
  "version": "0.1.7",
  "private": true,
  "productName": "Rovik",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "desktop:pack:app": "electron-packager . Rovik --platform=win32 --arch=x64 --out=dist-electron --overwrite --ignore=dist-electron --ignore=docs --ignore=supabase --ignore=\\.git --ignore=\\.vercel --ignore=\\.next[/\\\\]cache --ignore=\\.env.* --ignore=.*\\.log",
    "desktop:pack": "npm run build && npm run desktop:pack:app",
    "desktop:dist:installer": "electron-builder --win nsis --prepackaged dist-electron/Rovik-win32-x64 --publish never",
    "desktop:dist": "npm run build && npm run desktop:pack:app && npm run desktop:dist:installer"
  },
  "build": {
    "appId": "com.rovik.desktop",
    "productName": "Rovik",
    "executableName": "Rovik",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Rovik-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  },
  "description": "Eve is a browser-based prototype for Rovik's home operations assistant. It pairs a centered robot head UI with a speech-synced face, Gemini-backed responses, and a responsive chat surface built for Vercel deployment.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Peace1576/Rovik-1.0.1-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Peace1576/Rovik-1.0.1-/issues"
  },
  "homepage": "https://github.com/Peace1576/Rovik-1.0.1-#readme"
}
